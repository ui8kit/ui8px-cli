{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "noEmit": true,
    "target": "ES2022",
    "allowJs": false
  },
  "include": ["vite.config.js", "eslint.config.js", "src/**/*"]
}
