  },
  "recipes": {
    "pageArchetypes": {
      "landing": {
        "purpose": "Turn first-time visitors into interested diners through atmosphere, menu promise, trust, and reservation intent.",
        "requiredSections": [
          "hero-photo-overlay",
          "value-or-story-intro",
          "chef-or-menu-promo",
          "featured-dishes-grid",
          "testimonials-strip",
          "reservation-cta",
          "contact-or-location"
