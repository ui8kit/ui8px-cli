  "brandThesis": {
    "summary": "RestA should feel warm, refined, appetizing, and welcoming without becoming kitschy or generic.",
    "promise": "Turn restaurant discovery, reservation, and menu storytelling into an elegant but approachable digital experience.",
    "positioning": "A hospitality-centered brand system that blends polished rose-accented promotion with practical dining and operations clarity.",
    "personality": [
      "warm",
      "welcoming",
      "polished",
      "sensory",
      "celebratory",
      "approachable-premium",
      "hospitality-first"
    ],
    "antiPersonality": [
      "cold-enterprise",
      "clinical-minimalist",
      "fast-food-generic",
      "cyberpunk-tech",
      "over-styled-luxury",
      "cartoonish-playful"
    ],
    "emotionalOutcomes": [
      "appetite",
      "trust",
      "warmth",
      "desire",
      "comfort",
      "confidence"
    ],
    "voice": {
      "tone": [
        "inviting",
        "clear",
        "flavor-forward",
        "hospitality-minded",
        "confident",
        "friendly"
      ],
      "avoid": [
        "corporate jargon",
        "overly technical copy",
        "cheap promo hype",
        "dry operational language on guest surfaces",
        "generic luxury clichés"
      ]
    },
    "audienceProfiles": {
      "landing": "Potential diners evaluating atmosphere, cuisine, and trust before making a reservation or viewing the menu.",
      "blog": "Guests and readers interested in recipes, chef stories, promotions, events, seasonal menus, and restaurant culture.",
      "cms": "Restaurant staff managing menus, promotions, reservations, content, and testimonials.",
      "dashboard": "Owners and managers tracking reservations, occupancy, reviews, promotions, and menu performance.",
      "docs": "Internal operators, integrators, or product teams documenting restaurant workflows and brand usage."
    }
  },
  "operatingPrinciples": [
    {
      "id": "hospitality-first",
      "rule": "Every surface should feel like service, not just interface."
    },
    {
      "id": "appetite-before-noise",
      "rule": "Use food imagery, tone, and warmth to create desire without clutter."
    },
    {
      "id": "promotion-with-taste",
      "rule": "Promotional emphasis should feel elegant and inviting, not loud."
    },
    {
      "id": "signature-display-restraint",
      "rule": "Use script display moments sparingly for charm and brand recognition."
    },
    {
      "id": "brand-beyond-marketing",
      "rule": "Carry the same hospitality DNA into CMS, dashboard, and docs without forcing marketing styling into operational screens."
    }
  ],
