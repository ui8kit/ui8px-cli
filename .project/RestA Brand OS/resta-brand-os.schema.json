    "docs": {
      "generatedKitTitle": "RestA Brand OS Generated Kit",
      "promptTitlePrefix": "RestA Brand OS",
      "parserFixtureTitle": "RestA Brand OS Parser Fixtures",
      "parserFixtureReference": "`RestA Brand OS/reference`"
    },
    "assets": [
      {
        "source": "resta-brand-os.adapters/shared/tokens.css",
        "output": "adapters/shared/tokens.css",
        "description": "Shared brand tokens and plain CSS utilities."
      },
      {
        "source": "resta-brand-os.adapters/tailwind3/theme.css",
