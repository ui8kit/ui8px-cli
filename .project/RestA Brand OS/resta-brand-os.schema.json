    "name": "RestA Brand OS",
    "slug": "resta-brand-os",
    "status": "draft",
    "language": "en",
    "description": "A machine-readable brand operating system for a warm, polished, hospitality-first restaurant brand system built from the RoseUI reference language and aligned toward future Tailwind 4 and UI8Kit-compatible templates.",
    "sourceReference": {
      "project": "RoseUI restaurant references",
      "signalsPreserved": [
        "rose and zinc palette balance",
        "Nunito everyday UI typography",
        "Pacifico signature display moments",
        "rounded medium cards and controls",
        "food-first photography",
        "dark photo overlays for hero sections",
        "solid rose CTAs and outline secondary CTAs",
        "testimonial and menu presentation patterns"
      ],
      "signalsStrengthened": [
        "semantic token taxonomy",
        "brand prompts for app and content surfaces",
        "parser-aware conversion rules",
        "cross-surface consistency beyond static marketing pages",
        "Tailwind 3 and Tailwind 4 adapter separation",
        "future UI8Kit compatibility planning"
      ]
    },
    "intendedSurfaces": [
      "landing",
      "menu",
      "promotions",
      "blog",
      "reservations-cms",
      "restaurant-dashboard",
      "docs",
      "open-graph",
      "poster",
      "story"
    ]
  },
