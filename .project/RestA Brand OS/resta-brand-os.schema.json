    "shapeLanguage": {
      "core": "Soft, approachable, medium-rounded hospitality UI with occasional pill controls and larger promo shells.",
      "heroShell": "shell",
      "cardShell": "card",
      "interactiveChrome": "pill",
      "avoid": [
        "hard industrial corners",
        "massive playful bubbles",
        "hyper-luxury ornate framing"
      ]
    },
    "surfaceLanguage": {
      "base": "Light neutral or dark zinc surfaces with rose accents and gentle contrast shifts.",
      "depthRule": "Use soft card elevation for information clusters and darker overlays for food photography.",
      "accentRule": "Rose is the lead emotional accent; use it with discipline and pair it with neutral zinc support.",
      "contrastRule": "Restaurant surfaces should feel appetizing and readable, not flat or clinical."
    },
    "imageTreatment": {
      "style": "Aspirational but believable food and dining photography with strong crop discipline and dark overlays where needed.",
      "preferred": [
        "hero photos with dark overlays",
        "menu or dish cards with gradient overlays",
        "elegant interior and ingredient photography",
        "testimonial portraits or guest avatars"
      ],
      "avoid": [
        "generic stock office imagery",
        "over-saturated fake food renders",
        "tech-product screenshots as primary hero assets"
      ]
    },
