          "copy",
          "cta",
          "image"
        ],
        "fixedTraits": [
          "balanced split layout",
          "soft rounded imagery",
          "guest-facing copy tone"
        ]
      },
      "gradient-promo-cta": {
        "purpose": "Highlight an offer, club, event, or reservation push using warmer rose-led emphasis.",
        "requiredSlots": [
          "headline",
          "copy",
          "primary-cta",
          "secondary-cta"
        ],
        "fixedTraits": [
          "rose or pink gradient support",
          "simple CTA row",
          "strong visual contrast"
        ]
      },
      "featured-dishes-grid": {
        "purpose": "Show signature dishes or menu highlights with clear appetite cues.",
        "requiredSlots": [
          "section-heading",
          "dish-cards"
        ],
        "fixedTraits": [
          "image-first food cards",
          "price visibility",
          "short supporting copy"
        ]
      },
      "menu-list": {
        "purpose": "Present menu items clearly with hospitality tone and elegant separators.",
        "requiredSlots": [
          "section-heading",
          "items"
        ],
        "fixedTraits": [
          "two-column desktop rhythm where useful",
          "dotted or line separators",
          "name-price-description hierarchy"
        ]
      },
      "testimonial-grid": {
        "purpose": "Build trust with guest stories and review signals.",
        "requiredSlots": [
          "section-heading",
          "testimonial-cards",
          "rating-or-proof"
