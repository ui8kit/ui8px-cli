    ]
  },
  "qualityGates": {
    "consistency": [
      "No more than one visual grammar per screen.",
      "Repeated patterns must be named or wrapped.",
      "Accent usage must remain selective."
    ],
    "accessibility": [
      "Body copy must preserve readable contrast in both modes.",
      "Motion must respect reduced-motion settings.",
