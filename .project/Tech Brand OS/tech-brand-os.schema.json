  "brandThesis": {
    "summary": "Thoughtful technology should feel precise without becoming cold and modern without losing warmth.",
    "promise": "Turn technical complexity into clear, trusted, and human-centered experiences.",
    "positioning": "A premium but approachable technology brand system that blends editorial calm with product clarity.",
    "personality": [
      "warm",
      "intelligent",
      "calm",
      "precise",
      "human",
      "editorial",
      "tactile"
    ],
    "antiPersonality": [
      "generic-saas",
      "neon-cyberpunk",
      "cold-enterprise",
      "playful-chaotic",
      "glassmorphism-heavy",
      "over-animated"
    ],
    "emotionalOutcomes": [
      "trust",
      "clarity",
      "curiosity",
      "focus",
      "confidence"
    ],
    "voice": {
      "tone": [
        "clear",
        "thoughtful",
        "measured",
        "confident",
        "non-hype"
      ],
      "avoid": [
        "buzzword stacks",
        "aggressive urgency",
        "clickbait",
        "snark",
        "forced futurism"
      ]
    },
    "audienceProfiles": {
      "landing": "Decision-makers and practitioners evaluating a product or platform for trust, clarity, and differentiation.",
      "blog": "Readers looking for insight, perspective, product thinking, and thoughtful editorial content.",
      "cms": "Operators and content managers who need safe, predictable editing workflows.",
      "dashboard": "Teams that need fast scanning, confident decisions, and low-noise information density.",
      "docs": "Developers and technical users who need navigable, readable, and trustworthy documentation."
    }
  },
  "operatingPrinciples": [
    {
      "id": "meaning-first",
      "rule": "Design for comprehension before decoration."
    },
    {
      "id": "brand-through-grammar",
      "rule": "Distinctiveness comes from typography, spacing, surfaces, and composition before one-off effects."
    },
    {
      "id": "system-before-campaign",
      "rule": "Preserve a stable system layer and isolate campaign or decorative styling."
    },
    {
      "id": "calm-technology",
      "rule": "Use restraint, confidence, and tactile warmth instead of flashy futurism."
    },
    {
      "id": "promptable-design",
      "rule": "All important brand signals should be expressible in human and machine-readable form."
    }
  ],
