  "designGrammar": {
    "densityModes": {
      "landing": "airy",
      "blog": "balanced",
      "cms": "balanced-compact",
      "dashboard": "compact",
      "docs": "balanced"
    },
    "shapeLanguage": {
      "core": "Rounded, soft, tactile, and intentional rather than playful.",
      "heroShell": "radius.shell",
      "mediaFrame": "radius.media",
      "interactiveChrome": "radius.pill",
      "avoid": [
        "sharp glass panels",
        "aggressive skewed shapes",
        "ornamental blobs without content purpose"
      ]
    },
    "surfaceLanguage": {
      "base": "Soft neutral background with slightly warmer cards and restrained elevation.",
      "depthRule": "Use at most 3 obvious surface levels on a single screen.",
      "accentRule": "Accent is supportive, not dominant.",
      "contrastRule": "Use charcoal foreground for authority and legibility."
    },
    "imageTreatment": {
      "style": "Editorial product framing with calm contrast and generous crop discipline.",
      "preferred": [
        "product screenshots inside soft frames",
        "editorial photos with controlled overlays",
        "diagrammatic illustrations using brand shapes"
      ],
      "avoid": [
        "synthetic neon renders",
        "over-sharpened screenshots",
        "stock imagery with generic startup tropes"
      ]
    },
    "contentVoice": {
      "adjectives": [
        "thoughtful",
        "credible",
        "measured",
        "human",
        "technical-but-readable"
      ],
      "avoid": [
        "salesy",
        "breathless",
        "clickbait",
        "self-congratulatory"
      ]
    }
  },
  "recipes": {
    "pageArchetypes": {
      "landing": {
        "purpose": "Position a product, establish trust, and drive one primary CTA.",
        "requiredSections": [
          "hero-editorial-tech",
          "proof-strip",
          "feature-narrative",
          "feature-grid",
          "final-cta"
        ]
      },
      "blog-index": {
        "purpose": "Present the editorial voice, featured stories, categories, and subscription path.",
        "requiredSections": [
          "hero-editorial-tech",
          "intro-statement",
          "article-card-grid",
          "newsletter-cta"
        ]
      },
      "article": {
        "purpose": "Maximize readability, author trust, and related-content continuation.",
        "requiredSections": [
          "article-hero",
          "article-body",
          "tag-strip",
          "related-content-grid"
        ]
      },
      "cms": {
        "purpose": "Support safe creation, editing, moderation, and publishing workflows.",
        "requiredSections": [
          "cms-topbar",
          "cms-list-panel",
          "cms-detail-editor",
          "activity-or-help-panel"
        ]
      },
      "dashboard": {
        "purpose": "Enable fast scanning, anomaly detection, and confident decision-making.",
        "requiredSections": [
          "dashboard-header",
          "metric-summary-grid",
          "chart-panel-row",
          "table-panel"
        ]
      },
      "docs": {
        "purpose": "Make technical information navigable, readable, and trustworthy.",
        "requiredSections": [
          "docs-hero",
          "docs-sidebar-layout",
          "docs-article-shell",
          "callout-and-code-patterns"
        ]
      }
    },
    "sectionArchetypes": {
      "hero-editorial-tech": {
        "purpose": "Combine product or editorial authority with warmth and immediate comprehension.",
        "requiredSlots": [
          "eyebrow",
          "headline",
          "supporting-copy",
          "primary-cta",
          "secondary-action",
          "visual-frame"
        ],
        "fixedTraits": [
          "large rounded shell",
          "display heading",
          "clear single primary action",
          "strong but quiet focal image or product frame"
        ]
      },
      "proof-strip": {
        "purpose": "Reduce trust friction with logos, usage proof, metrics, or publication signals.",
        "requiredSlots": [
          "proof-items"
        ],
        "fixedTraits": [
          "low-noise presentation",
          "secondary emphasis only"
        ]
      },
      "feature-grid": {
        "purpose": "Summarize capabilities with consistent cards or tiles.",
        "requiredSlots": [
          "section-heading",
          "cards"
        ],
        "fixedTraits": [
          "shared card grammar",
          "balanced density",
          "clear icon/image hierarchy"
        ]
      },
      "feature-narrative": {
        "purpose": "Explain a core product idea or workflow with text + visual pairing.",
        "requiredSlots": [
          "section-heading",
          "body",
          "support-points",
          "visual"
        ],
        "fixedTraits": [
          "editorial cadence",
          "one dominant message",
          "calm asymmetry allowed"
        ]
      },
      "article-card-grid": {
        "purpose": "Present stories or resources in a signature branded card pattern.",
        "requiredSlots": [
          "cards"
        ],
        "fixedTraits": [
          "image-led cards",
          "tag + meta shell",
          "overlay-controlled readability",
          "floating action affordance optional"
        ]
      },
      "newsletter-cta": {
        "purpose": "Invite subscription without breaking brand calm.",
        "requiredSlots": [
          "headline",
          "copy",
          "input",
          "submit"
        ],
        "fixedTraits": [
          "single input row on desktop",
          "rounded CTA shell",
          "trustworthy, not pushy"
        ]
      },
      "metric-summary-grid": {
        "purpose": "Surface the most important numbers first in dashboard contexts.",
        "requiredSlots": [
          "metric-cards"
        ],
        "fixedTraits": [
          "low-noise cards",
          "clear hierarchy of number > label > delta",
          "semantic status colors only when necessary"
        ]
      },
      "docs-article-shell": {
        "purpose": "Support long-form technical reading, copyable code, and navigable headings.",
        "requiredSlots": [
          "title",
          "meta",
          "body",
          "code",
          "callouts"
        ],
        "fixedTraits": [
          "sans headings",
          "mono for code",
          "calm line length",
          "strong anchor navigation"
        ]
      }
    }
  },
  "componentPolicy": {
    "keepStandard": [
      "Button",
      "Input",
      "Textarea",
      "Select",
      "Tabs",
      "Accordion",
      "Dialog",
      "Sheet",
      "Tooltip",
      "Toast",
      "Badge"
    ],
    "wrapEarly": [
      "Section",
      "SectionHeader",
      "HeroShell",
      "NewsletterForm",
      "CategoryBadge",
      "MetricCard",
      "SocialIconButton",
      "ProofStrip",
      "FeatureCard",
      "DocsCallout"
    ],
    "customBlocks": [
      "LandingHero",
      "BlogHero",
      "ArticleCard",
      "EditorialCTA",
      "DashboardSummaryGrid",
      "CMSListDetailShell",
      "DocsPageShell"
    ],
    "rawHtmlAllowedFor": [
      "semantic article content",
      "markdown-rendered prose",
      "simple content wrappers inside named brand blocks"
    ],
    "avoid": [
      "rebuilding shadcn primitives for uniqueness alone",
      "page-specific component variants",
