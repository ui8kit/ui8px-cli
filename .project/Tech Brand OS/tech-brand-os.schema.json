  "schemaVersion": "1.0.0",
  "id": "tech-brand-os",
  "kind": "brand-operating-system",
  "meta": {
    "name": "Tech Brand OS",
    "slug": "tech-brand-os",
    "status": "draft",
    "language": "en",
    "description": "A machine-readable brand operating system for a calm, intelligent, human-centered technology brand that extends a shadcn-compatible core with a stronger semantic, editorial, and multi-surface design language.",
    "sourceReference": {
      "project": "tech-blog-rounded-main",
      "signalsPreserved": [
        "warm neutral palette",
        "dark charcoal foreground",
        "soft sage accent",
        "large rounded shells",
        "pill navigation and CTA language",
        "serif display + sans body pairing",
        "image-led editorial cards",
        "restrained reveal motion"
      ],
      "signalsStrengthened": [
        "cross-surface consistency for landing/blog/cms/dashboard/docs",
        "semantic token taxonomy",
        "brand recipes",
        "illustration and poster outputs",
        "promptability for LLM systems",
        "parser-aware conversion rules"
      ]
    },
    "intendedSurfaces": [
      "landing",
      "blog-index",
      "article",
      "cms",
      "dashboard",
      "docs",
      "open-graph",
      "poster",
      "video-cover",
      "illustration"
    ]
  },
  "emit": {
    "docs": {
      "generatedKitTitle": "Tech Brand OS Generated Kit",
      "promptTitlePrefix": "Tech Brand OS",
      "parserFixtureTitle": "Tech Brand OS Parser Fixtures",
      "parserFixtureReference": "`tech-blog-rounded-main`"
    },
    "assets": [
      {
        "source": "tech-brand-os.adapters/shared/tokens.css",
        "output": "adapters/shared/tokens.css",
        "description": "Shared brand tokens and plain CSS utilities."
      },
      {
        "source": "tech-brand-os.adapters/tailwind3/theme.css",
