{
  "name": "ui8px",
  "version": "0.2.4",
  "description": "Framework-agnostic CLI for strict 8px utility-class linting, telemetry, and pattern discovery",
  "author": "UI8Kit",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "ui8px",
    "cli",
    "npx",
    "npm",
    "node",
    "8px",
    "tailwind",
    "validator",
    "spacing"
  ],
  "homepage": "https://github.com/ui8kit/ui8px-cli",
  "bugs": {
    "url": "https://github.com/ui8kit/ui8px-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ui8kit/ui8px-cli.git"
  },
  "bin": {
    "ui8px": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/ui8px.test.mjs",
    "preflight": "bash scripts/preflight.sh",
    "preflight:publish": "bash scripts/preflight.sh --skip-install",
    "prepublishOnly": "npm run preflight:publish"
  },
  "files": [
    "README.md",
    "docs",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
